# Public site address. On Vercel set it to your production URL.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Optional direct .mp4 URL for the looping background video.
# If empty, the site tries /public/assets/anime-bg.mp4.
NEXT_PUBLIC_BACKGROUND_VIDEO_URL=

# Use a long random string in production.
AUTH_SECRET=change_me_to_a_long_random_string

# Supabase project settings.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Discord Developer Portal -> OAuth2.
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=

# Comma-separated Site IDs allowed to open /admin.
# Example: ADMIN_IDS=u_abc123,u_def456
ADMIN_IDS=
