# Address used by the browser and Discord OAuth redirect.
# Local:
BASE_URL=http://localhost:3000

# Use a long random string in production.
SESSION_SECRET=change_me_to_a_long_random_string

# Discord Developer Portal -> OAuth2.
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=

# Comma-separated Site IDs allowed to open /admin.
# Example: ADMIN_IDS=u_abc123,u_def456
ADMIN_IDS=

# Folder for SQLite files. On hosting, point this to persistent storage if available.
DATA_DIR=.

# Set to true only when the site is served over HTTPS and the proxy is trusted.
COOKIE_SECURE=false
TRUST_PROXY=false
